    {
      "id": 20,
      "page": null,
      "type": "ListItem",
      "text": "2. Summary of Findings",
      "section_path": "2. Summary of Findings"
    },
    {
      "id": 21,
      "page": null,
      "type": "Title",
      "text": "2.1 Overall assessment",
      "section_path": "2.1 Overall assessment"
    },
    {
      "id": 22,
      "page": null,
      "type": "ListItem",
      "text": "Overall control environment: Needs Improvement.",
      "section_path": "2.1 Overall assessment"
    },
    {
      "id": 23,
      "page": null,
      "type": "ListItem",
      "text": "Controls are generally designed appropriately but there are notable gaps in the operation of key controls around manual adjustments and Marketplace fee calculations.",
      "section_path": "2.1 Overall assessment"
    },
    {
      "id": 24,
      "page": null,
      "type": "Title",
      "text": "2.2 Summary of key findings",
      "section_path": "2.2 Summary of key findings"
    },
    {
      "id": 25,
      "page": null,
      "type": "ListItem",
      "text": "High‑severity:",
      "section_path": "2.2 Summary of key findings"
    },
    {
      "id": 26,
      "page": null,
      "type": "ListItem",
      "text": "Finding 1: Lack of independent review for manual revenue adjustments above USD 50,000.",
      "section_path": "2.2 Summary of key findings"
    },
    {
      "id": 27,
      "page": null,
      "type": "ListItem",
      "text": "Medium‑severity:",
      "section_path": "2.2 Summary of key findings"
    },
    {
      "id": 28,
      "page": null,
      "type": "ListItem",
      "text": "Finding 2: Inconsistent application of contract start dates for certain Services arrangements.",
      "section_path": "2.2 Summary of key findings"
    },
    {
      "id": 29,
      "page": null,
      "type": "ListItem",
      "text": "Finding 3: Delays in billing for Marketplace dispute resolutions impacting revenue cut‑off.",
      "section_path": "2.2 Summary of key findings"
    },
    {
      "id": 30,
      "page": null,
      "type": "ListItem",
      "text": "Low‑severity:",
      "section_path": "2.2 Summary of key findings"
    },
    {
      "id": 31,
      "page": null,
      "type": "ListItem",
      "text": "Finding 4: Incomplete documentation of revenue recognition judgments for non‑standard contracts.",
      "section_path": "2.2 Summary of key findings"
    },
    {
      "id": 32,
      "page": null,
      "type": "ListItem",
      "text": "3. Detailed Findings",
      "section_path": "3. Detailed Findings"
    },
    {
      "id": 33,
      "page": null,
      "type": "Title",
      "text": "3.1 Finding 1 – Manual Revenue Adjustments (High)",
      "section_path": "3.1 Finding 1 – Manual Revenue Adjustments (High)"
    },
    {
      "id": 34,
      "page": null,
      "type": "Title",
      "text": "3.1.1 Condition",
      "section_path": "3.1.1 Condition"
    },
    {
      "id": 35,
      "page": null,
      "type": "NarrativeText",
      "text": "During the review of manual journal entries and point‑of‑sale adjustments, we identified several instances where revenue adjustments above USD 50,000 were posted without evidence of independent review or approval.",
      "section_path": "3.1.1 Condition"
    },
    {
      "id": 36,
      "page": null,
      "type": "Title",
      "text": "3.1.2 Criteria",
      "section_path": "3.1.2 Criteria"
    },
    {
      "id": 37,
      "page": null,
      "type": "NarrativeText",
      "text": "The Company’s Revenue Recognition Policy requires an independent review and documented approval for any manual adjustment exceeding USD 50,000.",
      "section_path": "3.1.2 Criteria"
    },
    {
      "id": 38,
      "page": null,
      "type": "Title",
      "text": "3.1.3 Cause",
      "section_path": "3.1.3 Cause"
    },
    {
      "id": 39,
      "page": null,
      "type": "ListItem",
      "text": "The ERP system does not enforce an approval workflow for large adjustments.",
      "section_path": "3.1.3 Cause"
    },
    {
      "id": 40,
      "page": null,
      "type": "ListItem",
      "text": "Local finance teams rely on informal email approvals that are not consistently retained.",
      "section_path": "3.1.3 Cause"
    },
    {
      "id": 41,
      "page": null,
      "type": "Title",
      "text": "3.1.4 Effect",
      "section_path": "3.1.4 Effect"
    },
    {
      "id": 42,
      "page": null,
      "type": "ListItem",
      "text": "Increased risk of error or inappropriate revenue recognition.",
      "section_path": "3.1.4 Effect"
    },
    {
      "id": 43,
      "page": null,
      "type": "ListItem",
      "text": "Potential misstatement of revenue if large manual corrections are not adequately reviewed.",
      "section_path": "3.1.4 Effect"
    },
    {
      "id": 44,
      "page": null,
      "type": "Title",
      "text": "3.1.5 Recommendation",
      "section_path": "3.1.5 Recommendation"
    },
    {
      "id": 45,
      "page": null,
      "type": "ListItem",
      "text": "Implement a system‑enforced approval workflow for manual revenue adjustments above USD 50,000.",
      "section_path": "3.1.5 Recommendation"
    },
    {
      "id": 46,
      "page": null,
      "type": "ListItem",
      "text": "Require evidence of review (e.g., electronic sign‑off) to be retained with the journal entry.",
      "section_path": "3.1.5 Recommendation"
    },
    {
      "id": 47,
      "page": null,
      "type": "Title",
      "text": "3.1.6 Management Response",
      "section_path": "3.1.6 Management Response"
    },
    {
      "id": 48,
      "page": null,
      "type": "ListItem",
      "text": "Management agrees with the recommendation.",
      "section_path": "3.1.6 Management Response"
    },
    {
      "id": 49,
      "page": null,
      "type": "ListItem",
      "text": "Target remediation date: September 30, 2025.",
      "section_path": "3.1.6 Management Response"
    },
    {
      "id": 50,
      "page": null,
      "type": "ListItem",
      "text": "Owner: Director of Corporate Accounting.",
      "section_path": "3.1.6 Management Response"
    },
