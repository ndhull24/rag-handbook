    },
    {
      "id": 7,
      "page": null,
      "type": "NarrativeText",
      "text": "The objective of this internal audit was to assess the design and operating effectiveness of controls related to revenue recognition and billing for Aurora Retail Holdings, with a focus on:",
      "section_path": "1.1 Objective"
    },
    {
      "id": 8,
      "page": null,
      "type": "ListItem",
      "text": "Accuracy and completeness of revenue recorded;",
      "section_path": "1.1 Objective"
    },
    {
      "id": 9,
      "page": null,
      "type": "ListItem",
      "text": "Timeliness and accuracy of billing and invoicing;",
      "section_path": "1.1 Objective"
    },
    {
      "id": 10,
      "page": null,
      "type": "ListItem",
      "text": "Compliance with the Company’s Revenue Recognition Policy and applicable accounting standards.",
      "section_path": "1.1 Objective"
    },
    {
      "id": 11,
      "page": null,
      "type": "Title",
      "text": "1.2 Scope",
      "section_path": "1.2 Scope"
    },
    {
      "id": 12,
      "page": null,
      "type": "NarrativeText",
      "text": "1.2.1 The audit covered the period from January 1, 2024 to December 31, 2024.",
      "section_path": "1.2.1 The audit covered the period from January 1, 2024 to December 31, 2024."
    },
    {
      "id": 13,
      "page": null,
      "type": "NarrativeText",
      "text": "1.2.2 Scope included:",
      "section_path": "1.2.2 Scope included:"
    },
    {
      "id": 14,
      "page": null,
      "type": "NarrativeText",
      "text": "a) Core Retail sales (stores and owned e‑commerce)",
      "section_path": "1.2.2 Scope included:"
    },
    {
      "id": 15,
      "page": null,
      "type": "Title",
      "text": "b) Marketplace commissions and fees",
      "section_path": "b) Marketplace commissions and fees"
    },
