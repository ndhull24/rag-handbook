    {
      "id": 33,
      "page": null,
      "type": "Title",
      "text": "2.2 Commentary",
      "section_path": "2.2 Commentary"
    },
    {
      "id": 34,
      "page": null,
      "type": "ListItem",
      "text": "Revenue growth accelerated to 18.3% in Q4, driven by holiday demand and a strong promotional plan in our Core Retail segment.",
      "section_path": "2.2 Commentary"
    },
    {
      "id": 35,
      "page": null,
      "type": "ListItem",
      "text": "Gross margin expansion reflects improved inbound freight rates, a higher mix of private label, and disciplined markdown management.",
      "section_path": "2.2 Commentary"
    },
    {
      "id": 36,
      "page": null,
      "type": "ListItem",
      "text": "Operating expenses grew faster than sales due to:",
      "section_path": "2.2 Commentary"
    },
    {
      "id": 37,
      "page": null,
      "type": "ListItem",
      "text": "Wage rate increases implemented in Q2;",
      "section_path": "2.2 Commentary"
    },
    {
      "id": 38,
      "page": null,
      "type": "ListItem",
      "text": "Higher technology spend on digital capabilities;",
      "section_path": "2.2 Commentary"
    },
    {
      "id": 39,
      "page": null,
      "type": "ListItem",
      "text": "Incremental marketing investment to support Marketplace.",
      "section_path": "2.2 Commentary"
    },
    {
      "id": 40,
      "page": null,
      "type": "UncategorizedText",
      "text": "---",
      "section_path": "2.2 Commentary"
